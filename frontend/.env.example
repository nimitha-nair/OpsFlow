# Frontend (Vite) environment.
#
# DEPLOYMENT MODE: same-origin via the Cloudflare Pages Function proxy.
# Leave VITE_API_BASE_URL UNSET so the app uses the default "/api" base; the
# Pages Function (functions/api/[[path]].ts) forwards /api/* to the tunnel, so
# every request stays same-origin and no CORS is needed.
#
# Only set this if you deliberately want the app to call the backend directly
# (cross-origin) instead of via the same-origin proxy:
#   VITE_API_BASE_URL=https://api.example.com   (VITE_API_URL is an alias)
VITE_API_BASE_URL=
