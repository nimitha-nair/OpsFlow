# Frontend (Vite) environment.
#
# Backend API origin. In local dev you can leave this unset — the Vite dev server
# proxies "/api" to the backend (see vite.config.ts, BACKEND_URL).
#
# In production (Cloudflare Pages), set it to the Cloudflare Tunnel hostname that
# fronts the backend, e.g.:
#   VITE_API_BASE_URL=https://api.example.com
# (VITE_API_URL is accepted as an alias.)
#
# Alternative: leave this unset and add a Pages `_redirects` rule mapping
# /api/* -> the tunnel (same-origin, no CORS). See public/_redirects.example.
VITE_API_BASE_URL=
