PORT=5000

# Secret used to sign/verify auth JWTs. REQUIRED — the app refuses to start
# signing tokens if this is empty. Use a long, random value.
# Set the real value in a local, gitignored .env (NOT here).
JWT_SECRET=replace-with-a-long-random-secret

# Optional overrides for the default admin seed (npm run seed:admin).
# Defaults: admin@opsflow.local / Admin@123 — change the password after first login.
ADMIN_EMAIL=admin@opsflow.local
ADMIN_PASSWORD=Admin@123

# Performance / resilience knobs.
# Skip the default-admin Firestore read on every boot once the admin exists.
# SKIP_ADMIN_SEED=1
# Analytics/report cache TTL in ms (repeated refreshes within this window don't
# re-hit Firestore; writes also invalidate immediately). Default 30000.
# ANALYTICS_CACHE_TTL_MS=30000
# Log every Firestore read (collection · doc count · ms) to spot expensive scans.
# LOG_FIRESTORE_READS=1

# Firebase Admin credentials. Two options (env is preferred for deployment so no
# secret file ships in the image):
#   1. These three env vars (FIREBASE_PRIVATE_KEY keeps literal \n sequences).
#   2. A JSON key file via SERVICE_ACCOUNT_PATH (or backend/../secrets/service-account.json).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional: absolute path to a service-account JSON key (used only if the three
# FIREBASE_* vars above are not all set).
# SERVICE_ACCOUNT_PATH=/etc/opsflow/service-account.json

# ── Deployment: Cloudflare Pages (frontend) + Cloudflare Tunnel (backend) ──────
# Comma-separated list of browser origins allowed to call this API via CORS.
# Set to your Pages URL(s) in production, e.g.:
#   CORS_ORIGINS=https://opsflow.pages.dev,https://app.example.com
# When unset, all origins are reflected (fine for local dev; set it in prod).
CORS_ORIGINS=

# The backend sits behind Cloudflare Tunnel (cloudflared). Trust that proxy hop so
# rate limiting / req.ip use the real client IP from X-Forwarded-For. A hop count
# ("1"), "true"/"false", or an express trust-proxy string. Defaults to 1 when
# NODE_ENV=production, off otherwise.
TRUST_PROXY=1

# Document storage backend for expense receipts/invoices:
#   local    - files on disk under backend/uploads/expenses (development default)
#   firebase - objects in a Firebase Storage bucket (production)
# The AI/Kimi extractor reads through this backend either way.
STORAGE_BACKEND=local

# Firebase Storage bucket for expense receipts/invoices.
# REQUIRED only when STORAGE_BACKEND=firebase (ignored for local disk).
#
# PREREQUISITE: Firebase Storage must be enabled on the project, which requires
# the Blaze (pay-as-you-go) billing plan. Until billing is enabled NO bucket
# exists, and every upload fails with "The specified bucket does not exist" —
# the file is never stored and no expenseDocuments record is written.
#
# Use the exact name shown in Firebase Console -> Storage. Projects created since
# late 2024 use "<project>.firebasestorage.app"; older ones use "<project>.appspot.com".
# e.g. opsflow-cc01b.firebasestorage.app  (or opsflow-cc01b.appspot.com)
FIREBASE_STORAGE_BUCKET=

# Dev-only: relax the login rate limit (production stays at 10/15min).
AUTH_RATE_LIMIT=1000

# Set to "production" to enable strict rate limits and HSTS behavior.
NODE_ENV=development

# AI extractor provider: "mock" (no network) or "kimi" (NVIDIA Build).
AI_PROVIDER=kimi

# NVIDIA Build API key. REQUIRED when AI_PROVIDER=kimi.
# Put the REAL key in a local, gitignored .env — never commit it here.
NVIDIA_API_KEY=api_key

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

NVIDIA_MODEL=moonshotai/kimi-k2.6

# Per-request timeout (ms) for NVIDIA Build calls. A timeout is treated as a
# retryable network failure (exponential backoff + jitter). Default 30000.
NVIDIA_TIMEOUT_MS=30000